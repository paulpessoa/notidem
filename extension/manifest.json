{
  "manifest_version": 3,
  "name": "Notidem — thoughtful replies for LinkedIn",
  "version": "2.0.0",
  "description": "The opposite of 'idem'. Draft genuine, on-brand LinkedIn comments and replies in your own voice, always reviewed by you.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.groq.com https://api.openai.com https://generativelanguage.googleapis.com https://api.anthropic.com"
  },
  "host_permissions": [
    "https://api.groq.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["src/content.js"],
      "css": ["src/ui/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/ui/popup.html",
    "default_title": "Notidem",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png"
    }
  },
  "options_page": "src/ui/options.html",
  "web_accessible_resources": [
    {
      "resources": ["vendor/pdf.worker.min.js"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
